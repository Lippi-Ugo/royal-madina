---
import Layout from "../layouts/Layout.astro";
import FondHero from "../assets/fond-hero.webp";
---

<Layout titre="Confirmer ma commande">
    <section
        class="relative overflow-hidden min-h-96 flex items-center bg-cover bg-center bg-no-repeat"
        style={`background-image: url(${FondHero.src});`}
    >
        <div class="absolute inset-0 bg-[#f5e6d3]/70"></div>
        <div class="container mx-auto px-4 py-16 relative z-10">
            <h1 class="text-6xl font-bold text-gray-900">
                CONFIRMER MA COMMANDE
            </h1>
        </div>
    </section>

    <section class="bg-[#f5e6d3] py-16 md:py-24">
        <div class="container mx-auto px-4">
            <!-- Modal Popup -->
            <div
                id="modal-overlay"
                class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 items-center justify-center p-4 animate-fade-in hidden"
            >
                <div
                    class="bg-linear-to-br from-white to-[#f5e6d3] rounded-3xl shadow-2xl p-12 max-w-lg w-full animate-slide-up border-4 border-[#c9302c]"
                >
                    <div
                        class="flex items-center justify-center w-16 h-16 rounded-full bg-linear-to-br from-[#c9302c] to-[#a02622] mb-6 mx-auto"
                    >
                        <svg
                            id="modal-icon"
                            class="w-8 h-8 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <h3
                        id="modal-title"
                        class="text-3xl font-bold text-gray-900 mb-4 text-center"
                    >
                    </h3>
                    <p
                        id="modal-message"
                        class="text-gray-700 mb-8 text-center text-lg leading-relaxed"
                    >
                    </p>
                    <button
                        id="modal-close-btn"
                        class="w-full bg-linear-to-r from-[#c9302c] to-[#a02622] hover:shadow-lg text-white font-bold py-4 px-6 rounded-full transition-all transform hover:scale-105 text-lg"
                    >
                        Compris
                    </button>
                </div>
            </div>

            <style>
                @keyframes fade-in {
                    from {
                        opacity: 0;
                    }
                    to {
                        opacity: 1;
                    }
                }

                @keyframes slide-up {
                    from {
                        transform: translateY(30px);
                        opacity: 0;
                    }
                    to {
                        transform: translateY(0);
                        opacity: 1;
                    }
                }

                .animate-fade-in.flex {
                    animation: fade-in 0.3s ease-out;
                }

                .animate-slide-up {
                    animation: slide-up 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
                }
            </style>

            <div class="grid lg:grid-cols-3 gap-8">
                <!-- Formulaire -->
                <div class="lg:col-span-2">
                    <form
                        id="form-commande"
                        class="bg-white rounded-3xl border-2 border-[#d4b896] p-8 space-y-6"
                    >
                        <h2 class="text-3xl font-bold text-gray-900 mb-8">
                            Vos informations
                        </h2>

                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label
                                    class="block text-gray-700 font-bold mb-2"
                                    >Prénom</label
                                >
                                <input
                                    required
                                    type="text"
                                    name="prenom"
                                    class="w-full px-4 py-3 border-2 border-[#d4b896] rounded-2xl focus:outline-none focus:border-[#c9302c]"
                                    placeholder="Jean"
                                />
                            </div>
                            <div>
                                <label
                                    class="block text-gray-700 font-bold mb-2"
                                    >Nom</label
                                >
                                <input
                                    required
                                    type="text"
                                    name="nom"
                                    class="w-full px-4 py-3 border-2 border-[#d4b896] rounded-2xl focus:outline-none focus:border-[#c9302c]"
                                    placeholder="Dupont"
                                />
                            </div>
                        </div>

                        <div>
                            <label class="block text-gray-700 font-bold mb-2"
                                >Email</label
                            >
                            <input
                                required
                                type="email"
                                name="email"
                                class="w-full px-4 py-3 border-2 border-[#d4b896] rounded-2xl focus:outline-none focus:border-[#c9302c]"
                                placeholder="jean@example.com"
                            />
                        </div>

                        <div>
                            <label class="block text-gray-700 font-bold mb-2"
                                >Téléphone</label
                            >
                            <input
                                required
                                type="tel"
                                name="telephone"
                                class="w-full px-4 py-3 border-2 border-[#d4b896] rounded-2xl focus:outline-none focus:border-[#c9302c]"
                                placeholder="06 12 34 56 78"
                            />
                        </div>

                        <div>
                            <label class="block text-gray-700 font-bold mb-3"
                                >Mode de livraison</label
                            >
                            <div class="space-y-3">
                                <label class="flex items-center">
                                    <input
                                        required
                                        type="radio"
                                        name="type_commande"
                                        value="livraison"
                                        class="mr-3"
                                        checked
                                    />
                                    <span class="text-gray-700">Livraison</span>
                                </label>
                                <label class="flex items-center">
                                    <input
                                        type="radio"
                                        name="type_commande"
                                        value="emporter"
                                        class="mr-3"
                                    />
                                    <span class="text-gray-700">À emporter</span
                                    >
                                </label>
                            </div>
                        </div>

                        <div id="section-livraison" class="space-y-4">
                            <div>
                                <label
                                    class="block text-gray-700 font-bold mb-2"
                                    >Adresse de livraison</label
                                >
                                <input
                                    type="text"
                                    name="adresse"
                                    class="w-full px-4 py-3 border-2 border-[#d4b896] rounded-2xl focus:outline-none focus:border-[#c9302c]"
                                    placeholder="123 Rue de la Paix, 75001 Paris"
                                />
                            </div>
                        </div>

                        <div class="grid md:grid-cols-1 gap-4">
                            <div>
                                <label
                                    class="block text-gray-700 font-bold mb-2"
                                    >Heure souhaitée</label
                                >
                                <input
                                    required
                                    type="time"
                                    id="heure-input"
                                    name="heure_souhaitee"
                                    class="w-full px-4 py-3 border-2 border-[#d4b896] rounded-2xl focus:outline-none focus:border-[#c9302c]"
                                />
                            </div>
                        </div>

                        <div>
                            <label class="block text-gray-700 font-bold mb-2"
                                >Notes (optionnel)</label
                            >
                            <textarea
                                name="notes"
                                class="w-full px-4 py-3 border-2 border-[#d4b896] rounded-2xl focus:outline-none focus:border-[#c9302c]"
                                placeholder="Vos préférences ou demandes spéciales..."
                                rows="3"></textarea>
                        </div>

                        <div
                            class="text-gray-600 text-sm bg-[#f5e6d3] p-4 rounded-2xl"
                        >
                            <p>
                                ✓ Vos informations seront utilisées uniquement
                                pour la livraison de votre commande.
                            </p>
                        </div>
                    </form>
                </div>

                <!-- Résumé -->
                <div class="lg:col-span-1">
                    <div
                        class="bg-white rounded-3xl border-2 border-[#d4b896] p-8 sticky top-8"
                    >
                        <h3 class="text-2xl font-bold mb-6">RÉSUMÉ</h3>

                        <div
                            id="commande-items"
                            class="space-y-3 mb-6 pb-6 border-b-2 border-[#d4b896]"
                        >
                            <!-- Items du panier -->
                        </div>

                        <div
                            class="space-y-4 mb-6 pb-6 border-b-2 border-[#d4b896]"
                        >
                            <div class="flex justify-between">
                                <span class="text-gray-600">Sous-total</span>
                                <span id="sous-total" class="font-bold"
                                    >0.00€</span
                                >
                            </div>
                            <div id="offre-section" class="hidden">
                                <div
                                    class="flex justify-between text-[#c9302c]"
                                >
                                    <span class="text-sm font-bold"
                                        >✓ Offre 1 pizza + 1 boisson</span
                                    >
                                    <span id="offre-reduction" class="font-bold"
                                        >-X.00€</span
                                    >
                                </div>
                            </div>
                        </div>

                        <div class="flex justify-between mb-8">
                            <span class="text-xl font-bold">TOTAL</span>
                            <span
                                id="total"
                                class="text-3xl font-bold text-[#c9302c]"
                                >0.00€</span
                            >
                        </div>

                        <button
                            type="submit"
                            form="form-commande"
                            id="btn-valider"
                            class="w-full bg-[#c9302c] hover:bg-[#a02622] text-white px-8 py-4 rounded-full font-bold text-lg transition-colors"
                        >
                            VALIDER &amp; PAYER
                        </button>

                        <a
                            href="/panier"
                            class="block text-center mt-4 text-[#c9302c] hover:underline font-semibold"
                        >
                            Retour au panier
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    interface PanierItem {
        type: "pizza" | "boisson";
        id: string;
        nom: string;
        prix: number;
        quantite: number;
    }

    // Vérifier si connecté
    const token = localStorage.getItem("auth_token");
    if (!token) {
        window.location.href = "/connexion";
    }

    const form = document.getElementById("form-commande") as HTMLFormElement;
    const btnValider = document.getElementById(
        "btn-valider",
    ) as HTMLButtonElement;
    const commandeItems = document.getElementById("commande-items");
    const sousTotal = document.getElementById("sous-total");
    const total = document.getElementById("total");
    const heureInput = document.getElementById(
        "heure-input",
    ) as HTMLInputElement;

    // Calculer l'heure minimum (maintenant + 30 min)
    const setMinimumHeure = () => {
        const now = new Date();
        const minimumTime = new Date(now.getTime() + 30 * 60000); // +30 min

        const heure = String(minimumTime.getHours()).padStart(2, "0");
        const minute = String(minimumTime.getMinutes()).padStart(2, "0");
        const minTimeStr = `${heure}:${minute}`;

        heureInput.min = minTimeStr;
        heureInput.max = "23:59";
    };

    setMinimumHeure();

    // Afficher modal personnalisé
    const showModal = (title: string, message: string) => {
        const modal = document.getElementById("modal-overlay");
        const modalTitle = document.getElementById("modal-title");
        const modalMessage = document.getElementById("modal-message");
        const closeBtn = document.getElementById("modal-close-btn");

        if (modalTitle) modalTitle.textContent = title;
        if (modalMessage) modalMessage.textContent = message;

        modal?.classList.remove("hidden");
        modal?.classList.add("flex");

        closeBtn?.addEventListener("click", () => {
            modal?.classList.add("hidden");
            modal?.classList.remove("flex");
        });

        // Fermer aussi en cliquant sur l'overlay
        modal?.addEventListener("click", (e) => {
            if (e.target === modal) {
                modal.classList.add("hidden");
                modal.classList.remove("flex");
            }
        });
    };

    // Validation au moment de quitter le champ heure (et non pendant la saisie)
    heureInput?.addEventListener("blur", (e) => {
        const heureValue = (e.target as HTMLInputElement).value;
        if (!heureValue) return;

        const [heure, minute] = heureValue.split(":").map(Number);
        const now = new Date();
        const selectedTime = new Date();
        selectedTime.setHours(heure, minute, 0);

        const minutesUntilOrder = Math.floor(
            (selectedTime.getTime() - now.getTime()) / 60000,
        );

        if (minutesUntilOrder < 30) {
            const minimumTime = new Date(now.getTime() + 30 * 60000);
            const minHeure = String(minimumTime.getHours()).padStart(2, "0");
            const minMinute = String(minimumTime.getMinutes()).padStart(2, "0");

            showModal(
                "Délai minimum",
                `Nous avons besoin d'un délai minimum de 30 minutes. Vous pouvez commander à partir de ${minHeure}:${minMinute}.`,
            );
            heureInput.value = "";
        }
    });

    const getPanier = (): PanierItem[] => {
        const raw = localStorage.getItem("panier");
        return raw ? JSON.parse(raw) : [];
    };

    const renderCommande = () => {
        const items = getPanier();

        if (items.length === 0) {
            window.location.href = "/panier";
            return;
        }

        commandeItems!.innerHTML = items
            .map(
                (item) => `
				<div class="flex justify-between items-center">
					<div>
						<p class="font-bold text-gray-900">${item.nom}</p>
						<p class="text-sm text-gray-600">x${item.quantite}</p>
					</div>
					<span class="font-bold">${(item.prix * item.quantite).toFixed(2)}€</span>
				</div>
			`,
            )
            .join("");

        const sousT = items.reduce(
            (sum, item) => sum + item.prix * item.quantite,
            0,
        );

        // Check if promo applies (1 pizza + 1 boisson exactly)
        const hasPizza = items.some((i) => i.type === "pizza");
        const hasBoisson = items.some((i) => i.type === "boisson");
        const isPromoApplicable = hasPizza && hasBoisson && items.length === 2;

        sousTotal!.textContent = sousT.toFixed(2) + "€";

        const offreSection = document.getElementById("offre-section");
        const offreReduction = document.getElementById("offre-reduction");

        if (isPromoApplicable) {
            const reduction = sousT - 10;
            offreReduction!.textContent = `-${reduction.toFixed(2)}€`;
            offreSection!.classList.remove("hidden");
            total!.textContent = "10.00€";
        } else {
            offreSection!.classList.add("hidden");
            total!.textContent = sousT.toFixed(2) + "€";
        }
    };

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const items = getPanier();
        const typeCommande = formData.get("type_commande") as string;
        const heureStr = formData.get("heure_souhaitee") as string;

        // Valider l'heure (18:00 - 23:59 et minimum 30 min)
        if (heureStr) {
            const [heure, minute] = heureStr.split(":").map(Number);
            if (heure < 18) {
                showModal(
                    "Horaire",
                    "Nous ouvrons à 18h. Veuillez choisir une heure à partir de 18:00.",
                );
                return;
            }

            // Vérifier que l'heure est au minimum 30 minutes from now
            const now = new Date();
            const selectedTime = new Date();
            selectedTime.setHours(heure, minute, 0);

            const minutesUntilOrder = Math.floor(
                (selectedTime.getTime() - now.getTime()) / 60000,
            );

            if (minutesUntilOrder < 30) {
                showModal(
                    "Délai minimum",
                    `Nous avons besoin d'un délai minimum de 30 minutes.Vous pouvez commander à partir de ${String(new Date(now.getTime() + 30 * 60000).getHours()).padStart(2, "0")}:${String(new Date(now.getTime() + 30 * 60000).getMinutes()).padStart(2, "0")}.`,
                );
                return;
            }
        }

        try {
            (btnValider as HTMLButtonElement).disabled = true;
            btnValider.style.opacity = "0.5";
            btnValider.textContent = "Paiement en cours...";

            const res = await fetch("/routes/paiement/create-session", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    items,
                    infos: {
                        prenom: formData.get("prenom"),
                        nom: formData.get("nom"),
                        email: formData.get("email"),
                        telephone: formData.get("telephone"),
                        adresse:
                            typeCommande === "livraison"
                                ? formData.get("adresse")
                                : null,
                        type_commande: typeCommande,
                        heure_souhaitee: formData.get("heure_souhaitee"),
                        notes: formData.get("notes") || null,
                    },
                }),
            });

            const data = await res.json();
            if (data?.url) {
                window.location.href = data.url;
            } else {
                showModal(
                    "Erreur",
                    "Une erreur s'est produite lors du paiement. Veuillez réessayer.",
                );
                (btnValider as HTMLButtonElement).disabled = false;
                btnValider.style.opacity = "1";
                btnValider.textContent = "VALIDER & PAYER";
            }
        } catch {
            showModal(
                "Erreur",
                "Une erreur s'est produite lors du paiement. Veuillez réessayer.",
            );
            (btnValider as HTMLButtonElement).disabled = false;
            btnValider.style.opacity = "1";
            btnValider.textContent = "VALIDER & PAYER";
        }
    });

    // Gestion du formulaire en fonction du type de commande
    const typeCommandeInputs = document.querySelectorAll(
        'input[name="type_commande"]',
    );
    const sectionLivraison = document.getElementById("section-livraison");
    const adresseInput = form?.querySelector(
        'input[name="adresse"]',
    ) as HTMLInputElement | null;

    const updateFormVisibility = () => {
        const selected = form?.querySelector(
            'input[name="type_commande"]:checked',
        ) as HTMLInputElement;
        if (selected?.value === "livraison") {
            sectionLivraison?.classList.remove("hidden");
            if (adresseInput) adresseInput.required = true;
        } else {
            sectionLivraison?.classList.add("hidden");
            if (adresseInput) adresseInput.required = false;
        }
    };

    typeCommandeInputs.forEach((input) => {
        input.addEventListener("change", updateFormVisibility);
    });

    updateFormVisibility();

    renderCommande();
</script>
