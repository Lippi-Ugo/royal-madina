---
import Layout from "../../layouts/Layout.astro";
import FondHero from "../../assets/fond-hero.webp";
---

<Layout titre="Paiement Réussi">
    <section
        class="relative overflow-hidden min-h-screen flex items-center bg-cover bg-center bg-no-repeat"
        style={`background-image: url(${FondHero.src});`}
    >
        <div class="absolute inset-0 bg-[#f5e6d3]/70"></div>
        <div class="container mx-auto px-4 relative z-10">
            <div
                class="max-w-2xl mx-auto bg-white rounded-3xl p-12 border-2 border-[#d4b896]"
            >
                <div class="text-center">
                    <svg
                        class="w-24 h-24 mx-auto mb-8 text-[#c9302c]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path>
                    </svg>

                    <h1 class="text-5xl font-bold text-gray-900 mb-4">
                        Paiement réussi !
                    </h1>

                    <p class="text-xl text-gray-600 mb-8">
                        Merci pour votre commande. Vous recevrez bientôt votre
                        pizza fraîche !
                    </p>

                    <div class="space-y-4">
                        <a
                            href="/#carte"
                            class="block bg-[#c9302c] hover:bg-[#a02622] text-white px-8 py-4 rounded-full font-bold text-lg transition-colors"
                        >
                            Retour à l'accueil
                        </a>
                        <a
                            href="/panier"
                            class="block border-2 border-[#c9302c] text-[#c9302c] hover:bg-[#c9302c] hover:text-white px-8 py-4 rounded-full font-bold text-lg transition-colors"
                        >
                            Retour au panier
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    // Nettoyer le panier après un paiement réussi
    localStorage.removeItem("panier");
    console.log("✅ Panier vidé après paiement réussi");

    // Notifier le header que le panier a changé
    window.dispatchEvent(new CustomEvent("panier-updated"));
</script>
