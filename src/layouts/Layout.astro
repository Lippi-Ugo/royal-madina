---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
interface Props {
	titre: string;
}
const { titre } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- PWA Configuration -->
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#c9302c" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta
			name="apple-mobile-web-app-status-bar-style"
			content="black-translucent"
		/>
		<meta name="apple-mobile-web-app-title" content="Royal Madina" />
		<link rel="apple-touch-icon" href="/icon-192x192.png" />

		<title>{titre} | Royal Madina</title>
		<meta
			name="description"
			content="Découvrez nos pizzas artisanales halal préparées avec passion. Livraison et à emporter à Valentigney."
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap"
			rel="preload"
			as="style"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
	</head>
	<body class="font-sans antialiased relative min-h-screen overflow-x-hidden">
		<Header />

		<!-- Fond décoratif d'icônes (tous utilisés, certains plusieurs fois) -->
		<div
			aria-hidden="true"
			class="fixed inset-0 -z-10 pointer-events-none select-none"
		>
			<img
				src="/icons/pizza-rouge.svg"
				class="absolute top-10 left-8 w-20 opacity-20 rotate-12"
				alt=""
			/>
			<img
				src="/icons/pizza-jaune.svg"
				class="absolute top-1/3 left-1/2 w-16 opacity-10 -rotate-6"
				alt=""
			/>
			<img
				src="/icons/pizza-verte.svg"
				class="absolute bottom-10 left-1/3 w-20 opacity-10 rotate-3"
				alt=""
			/>
			<img
				src="/icons/part-pizza-rouge.svg"
				class="absolute bottom-1/3 left-10 w-14 opacity-20 -rotate-12"
				alt=""
			/>
			<img
				src="/icons/part-pizza-jaune.svg"
				class="absolute top-1/4 right-1/4 w-12 opacity-10 rotate-45"
				alt=""
			/>
			<img
				src="/icons/part-pizza-verte.svg"
				class="absolute bottom-1/4 right-1/3 w-14 opacity-10 -rotate-12"
				alt=""
			/>
			<img
				src="/icons/fourchette-jaune.svg"
				class="absolute top-1/2 left-1/4 w-16 opacity-20 -rotate-6"
				alt=""
			/>
			<img
				src="/icons/fourchette-rouge.svg"
				class="absolute bottom-1/2 right-1/4 w-14 opacity-10 rotate-12"
				alt=""
			/>
			<img
				src="/icons/fourchette-vert.svg"
				class="absolute top-1/5 right-10 w-12 opacity-10 -rotate-3"
				alt=""
			/>
			<img
				src="/icons/bonhomme-jaune.svg"
				class="absolute top-1/5 left-1/5 w-16 opacity-10 rotate-12"
				alt=""
			/>
			<img
				src="/icons/bonhomme-rouge.svg"
				class="absolute bottom-1/5 left-1/6 w-20 opacity-10 -rotate-6"
				alt=""
			/>
			<img
				src="/icons/bonhomme-vert.svg"
				class="absolute bottom-16 right-10 w-24 opacity-10 rotate-3"
				alt=""
			/>
			<img
				src="/icons/toque-jaune.svg"
				class="absolute top-1/4 right-12 w-16 opacity-10 rotate-45"
				alt=""
			/>
			<img
				src="/icons/toque-rouge.svg"
				class="absolute bottom-1/6 left-1/2 w-14 opacity-10 -rotate-12"
				alt=""
			/>
			<img
				src="/icons/toque-vert.svg"
				class="absolute top-1/2 right-1/6 w-16 opacity-10 rotate-12"
				alt=""
			/>

			<!-- Répétition pour effet de densité -->
			<img
				src="/icons/pizza-rouge.svg"
				class="absolute top-1/5 right-1/5 w-10 opacity-10 -rotate-12"
				alt=""
			/>
			<img
				src="/icons/bonhomme-jaune.svg"
				class="absolute bottom-1/4 right-1/4 w-12 opacity-10 rotate-6"
				alt=""
			/>
			<img
				src="/icons/fourchette-rouge.svg"
				class="absolute top-1/6 left-1/6 w-10 opacity-10 rotate-12"
				alt=""
			/>

			<!-- Répétition pour effet de densité -->
			<img
				src="/src/assets/icons/pizza-rouge.svg"
				class="absolute top-1/5 right-1/5 w-10 opacity-10 -rotate-12"
				alt=""
			/>
			<img
				src="/src/assets/icons/bonhomme-jaune.svg"
				class="absolute bottom-1/4 right-1/4 w-12 opacity-10 rotate-6"
				alt=""
			/>
			<img
				src="/src/assets/icons/fourchette-rouge.svg"
				class="absolute top-1/6 left-1/6 w-10 opacity-10 rotate-12"
				alt=""
			/>
		</div>

		<slot />
		<Footer />

		<!-- Service Worker Registration -->
		<script>
			if ("serviceWorker" in navigator) {
				navigator.serviceWorker.register("/sw.js").catch(() => {});
			}
		</script>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family:
			"Inter",
			system-ui,
			-apple-system,
			sans-serif;
	}

	* {
		box-sizing: border-box;
	}
</style>
