---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
interface Props {
	titre: string;
}
const { titre } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- PWA Configuration -->
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#c9302c" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta
			name="apple-mobile-web-app-status-bar-style"
			content="black-translucent"
		/>
		<meta name="apple-mobile-web-app-title" content="Royal Madina" />
		<link rel="apple-touch-icon" href="/icon-192x192.png" />

		<title>{titre} | Royal Madina</title>
		<meta
			name="description"
			content="Découvrez nos pizzas artisanales halal préparées avec passion. Livraison et à emporter à Valentigney."
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap"
			rel="preload"
			as="style"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
	</head>
	<body class="font-sans antialiased relative min-h-screen overflow-x-hidden">
		<Header />
		<slot />
		<Footer />

		<!-- Pop-up cookies -->
		<div
			id="cookie-popup"
			class="fixed inset-0 z-50 items-end sm:items-center justify-center bg-black/30 transition-all duration-300 hidden"
		>
			<div
				class="bg-white rounded-2xl shadow-xl p-6 max-w-md w-full m-4 border-2 border-[#c9302c]/30"
			>
				<h2 class="text-xl font-bold mb-2 text-[#c9302c]">
					Cookies & vie privée
				</h2>
				<p class="text-gray-700 mb-4 text-sm">
					Ce site utilise des cookies pour améliorer votre expérience
					et réaliser des statistiques anonymes. <a
						href="/politique-cookies"
						class="underline text-[#c9302c]">En savoir plus</a
					>.
				</p>
				<button
					id="cookie-accept"
					class="bg-[#c9302c] text-white px-5 py-2 rounded-lg font-semibold w-full hover:bg-[#a82320] transition"
					>J'accepte</button
				>
				<button
					id="cookie-refuse"
					class="bg-gray-200 text-gray-700 px-5 py-2 rounded-lg font-semibold w-full hover:bg-gray-300 transition border border-gray-300"
					>Je refuse</button
				>
			</div>
		</div>

		<!-- Service Worker Registration & Cookie Popup Script -->
		<script>
			if ("serviceWorker" in navigator) {
				navigator.serviceWorker.register("/sw.js").catch(() => {});
			}
			// Cookie consent popup
			window.addEventListener("DOMContentLoaded", () => {
				const popup = document.getElementById("cookie-popup");
				const accept = document.getElementById("cookie-accept");
				const refuse = document.getElementById("cookie-refuse");
				// Affiche le popup uniquement à la toute première visite (pas à chaque reload)
				if (
					popup &&
					!sessionStorage.getItem("cookie_popup_shown") &&
					localStorage.getItem("cookie_consent") === null
				) {
					popup.classList.remove("hidden");
					popup.classList.add("flex");
					sessionStorage.setItem("cookie_popup_shown", "1");
				}
				accept?.addEventListener("click", () => {
					localStorage.setItem("cookie_consent", "1");
					if (popup) {
						popup.classList.add("hidden");
						popup.classList.remove("flex");
					}
				});
				refuse?.addEventListener("click", () => {
					localStorage.setItem("cookie_consent", "0");
					if (popup) {
						popup.classList.add("hidden");
						popup.classList.remove("flex");
					}
				});
			});
		</script>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family:
			"Inter",
			system-ui,
			-apple-system,
			sans-serif;
	}

	* {
		box-sizing: border-box;
	}
</style>
