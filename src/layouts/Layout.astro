---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
interface Props {
	titre: string;
}
const { titre } = Astro.props;
const user = Astro.locals.user || null;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- PWA Configuration -->
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#c9302c" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta
			name="apple-mobile-web-app-status-bar-style"
			content="black-translucent"
		/>
		<meta name="apple-mobile-web-app-title" content="Royal Madina" />
		<link rel="apple-touch-icon" href="/icon-192x192.png" />

		<title>{titre} | Royal Madina</title>
		<meta
			name="description"
			content="Découvrez nos pizzas artisanales halal préparées avec passion. Livraison et à emporter à Valentigney."
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap"
			rel="preload"
			as="style"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
	</head>
	<body class="font-sans antialiased">
		<Header personne={user} />

		<slot />
		<Footer />

		<!-- Service Worker Registration -->
		<script>
			if ("serviceWorker" in navigator) {
				navigator.serviceWorker.register("/sw.js").catch(() => {});
			}
		</script>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family:
			"Inter",
			system-ui,
			-apple-system,
			sans-serif;
	}

	* {
		box-sizing: border-box;
	}
</style>
