---
import SnapLogo from "../assets/snap.svg";
import InstaLogo from "../assets/insta.svg";
import TiktokLogo from "../assets/tiktok.svg";
---

<footer class="bg-[#c9302c] text-white py-12">
    <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-8 mb-8">
            <div>
                <h3 class="text-2xl font-bold mb-4">ROYAL MADINA</h3>
                <p class="mb-2">Pizzeria Traditionnelle</p>
                <p class="mb-2">07 65 86 47 14</p>
                <p>25700 VALENTIGNEY</p>
            </div>
            <div>
                <h4 class="font-bold mb-4 text-lg">Horaires</h4>
                <p class="mb-1">Lundi - Dimanche</p>
                <p class="text-xl font-semibold">18h - 00h00</p>
            </div>
            <div class="flex gap-4 items-start justify-end">
                <a
                    href="#"
                    class="w-14 h-14 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors"
                    aria-label="Instagram"
                >
                    <img
                        src={InstaLogo.src}
                        alt="Instagram"
                        class="w-7 h-7 filter-[invert(16%)_sepia(91%)_saturate(1352%)_hue-rotate(353deg)]"
                    />
                </a>
                <a
                    href="#"
                    class="w-14 h-14 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors"
                    aria-label="TikTok"
                >
                    <img
                        src={TiktokLogo.src}
                        alt="TikTok"
                        class="w-7 h-7 filter-[invert(16%)_sepia(91%)_saturate(1352%)_hue-rotate(353deg)]"
                    />
                </a>
                <a
                    href="#"
                    class="w-14 h-14 bg-[#FFFC00] rounded-full flex items-center justify-center hover:bg-yellow-300 transition-colors"
                    aria-label="Snapchat"
                >
                    <img src={SnapLogo.src} alt="Snapchat" class="w-7 h-7" />
                </a>
            </div>
        </div>
        <div
            class="border-t border-white/20 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm"
        >
            <p>© Royal Madina 2026</p>
            <div class="flex gap-6">
                <a href="/CGV" class="hover:underline">CGV</a>
                <a href="/CGU" class="hover:underline">CGU</a>
                <a href="/mentions-legales" class="hover:underline"
                    >Mentions légales</a
                >
                <a href="/politique-confidentialite" class="hover:underline"
                    >Politique de confidentialité</a
                >
                <a href="/politique-cookies" class="hover:underline"
                    >Politique de cookies</a
                >
            </div>
        </div>
    </div>
</footer>
