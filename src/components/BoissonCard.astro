---
import type { BoissonsRecord } from "../pocketbase-types";
import ImgPb from "./ImgPb.astro";

interface Props {
    boisson: BoissonsRecord;
}

const { boisson } = Astro.props;

const details = [boisson.type, boisson.taille].filter(Boolean);
---

<article class="group relative flex flex-col h-full">
    <div class="mx-auto w-full max-w-105 flex-1 flex flex-col">
        <div id="product-card-image-wrapper" class="aspect-square">
            <ImgPb
                record={boisson}
                field="image"
                alt={boisson.nom || "Boisson"}
                classPicture="w-full h-full"
                classImg="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105"
                thumb="400x400"
            />
        </div>
        <h2
            class="mt-3 sm:mt-8 font-bold text-gray-900 text-lg sm:text-2xl md:text-4xl leading-tight uppercase text-center"
        >
            {boisson.nom || "Boisson"}
        </h2>
        <p
            class="mt-2 sm:mt-5 text-sm sm:text-base md:text-xl text-gray-700 text-center line-clamp-2 sm:line-clamp-none flex-1"
        >
            {
                details.length > 0
                    ? details.join(" - ")
                    : "Description non disponible"
            }
        </p>
        <p class="md:hidden mt-2 text-lg font-bold text-[#c9302c]">
            {boisson.prix?.toFixed(2)}€
        </p>
    </div>

    <button
        class="mt-4 sm:mt-7 w-full bg-[#c9302c] hover:bg-[#a02622] text-white py-2 sm:py-3 rounded-full font-bold text-sm sm:text-lg transition-colors add-to-cart-btn"
        data-item={JSON.stringify({
            type: "boisson",
            id: boisson.id,
            nom: boisson.nom,
            prix: boisson.prix,
        })}
    >
        COMMANDER
    </button>
</article>

<script>
    //@ts-ignore
    if (!window._cartListenerAttached) {
        document.addEventListener("click", (e) => {
            const btn = (e.target as HTMLElement).closest(".add-to-cart-btn");
            if (!btn) return;

            const itemStr = btn.getAttribute("data-item");
            if (!itemStr) return;

            try {
                const item = JSON.parse(itemStr);
                const panier = JSON.parse(
                    localStorage.getItem("panier") || "[]",
                );
                const existing = panier.find(
                    (p: any) => p.id === item.id && p.type === item.type,
                );

                if (existing) {
                    existing.quantite++;
                } else {
                    panier.push({ ...item, quantite: 1 });
                }

                localStorage.setItem("panier", JSON.stringify(panier));
                window.location.href = "/panier";
            } catch (err) {
                console.error("Erreur panier:", err);
            }
        });
        //@ts-ignore
        window._cartListenerAttached = true;
    }
</script>
